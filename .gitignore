# Secretos y entorno — NUNCA versionar (lección GSH)
.env
.env.*
!.env.example
secrets/*
!secrets/.gitkeep

# Artefactos
node_modules/
*.docx
*.pdf
nohup.out
*.log
__pycache__/

# Fotos subidas desde el panel (datos de produccion, no codigo)
sitio/uploads/*
!sitio/uploads/.gitkeep

# Volcados de NocoDB: llevan nombres, correos y telefonos de alumnos. Se
# guardan para poder restaurar, pero fuera del repositorio.
backups/
